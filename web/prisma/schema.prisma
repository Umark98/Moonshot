// ============================================================
// Crux Protocol — Production Database Schema
// ============================================================
// PostgreSQL via Supabase. Swap-ready: just change DATABASE_URL.
// Run: npx prisma db push   (dev)
// Run: npx prisma migrate deploy (prod)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────────────────────
// CORE PROTOCOL STATE (cached snapshots from on-chain)
// ─────────────────────────────────────────────────────────────

/// Standardized Yield vaults — one per yield-bearing asset
model SyVault {
  id               String   @id                        // on-chain object ID
  coinType         String   @map("coin_type")
  underlyingSymbol String   @map("underlying_symbol")
  totalUnderlying  Decimal  @default(0) @map("total_underlying") @db.Decimal(40, 0)
  totalSySupply    Decimal  @default(0) @map("total_sy_supply")  @db.Decimal(40, 0)
  exchangeRate     Decimal  @default(1000000000000000000) @map("exchange_rate") @db.Decimal(40, 0) // WAD
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  deposits    SyDeposit[]
  redemptions SyRedemption[]
  rateHistory RateSnapshot[]
  markets     Market[]

  @@map("sy_vaults")
}

/// Yield market configs — one per (asset, maturity) pair
model Market {
  id               String   @id                        // on-chain YieldMarketConfig ID
  vaultId          String   @map("vault_id")
  vault            SyVault  @relation(fields: [vaultId], references: [id])
  poolId           String?  @map("pool_id")            // AMM pool ID (null before pool creation)
  coinType         String   @map("coin_type")
  underlyingSymbol String   @map("underlying_symbol")
  maturityMs       BigInt   @map("maturity_ms")
  durationMonths   Int      @map("duration_months")

  // Cached AMM state (updated by indexer)
  impliedRate      Float    @default(0) @map("implied_rate")
  ptPrice          Float    @default(1) @map("pt_price")
  ytPrice          Float    @default(0) @map("yt_price")
  tvl              Float    @default(0)
  volume24h        Float    @default(0) @map("volume_24h")

  // Token supply
  totalPtSupply    Decimal  @default(0) @map("total_pt_supply") @db.Decimal(40, 0)
  totalYtSupply    Decimal  @default(0) @map("total_yt_supply") @db.Decimal(40, 0)

  // Settlement
  isSettled        Boolean  @default(false) @map("is_settled")
  settlementRate   Decimal? @map("settlement_rate") @db.Decimal(40, 0)
  settledAt        DateTime? @map("settled_at")

  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  swaps            Swap[]
  pyMints          PyMint[]
  liquidityEvents  LiquidityEvent[]
  settlements      MarketSettlement[]
  rateSnapshots    ImpliedRateSnapshot[]
  volumeSnapshots  VolumeSnapshot[]

  @@index([underlyingSymbol])
  @@index([maturityMs])
  @@index([isSettled])
  @@map("markets")
}

// ─────────────────────────────────────────────────────────────
// EVENT LOG (indexed from on-chain events)
// ─────────────────────────────────────────────────────────────

/// Raw on-chain events — append-only audit log
model Event {
  id          Int      @id @default(autoincrement())
  txDigest    String   @map("tx_digest")
  eventSeq    Int      @default(0) @map("event_seq")
  eventType   String   @map("event_type")
  packageId   String   @map("package_id")
  module      String
  sender      String?
  data        Json
  timestampMs BigInt   @map("timestamp_ms")
  createdAt   DateTime @default(now()) @map("created_at")

  @@unique([txDigest, eventSeq])
  @@index([eventType])
  @@index([timestampMs])
  @@index([module])
  @@index([sender])
  @@map("events")
}

/// SY deposits (underlying → SY wrap)
model SyDeposit {
  id               Int      @id @default(autoincrement())
  txDigest         String   @map("tx_digest")
  vaultId          String   @map("vault_id")
  vault            SyVault  @relation(fields: [vaultId], references: [id])
  depositor        String
  underlyingAmount Decimal  @map("underlying_amount") @db.Decimal(40, 0)
  syAmount         Decimal  @map("sy_amount") @db.Decimal(40, 0)
  exchangeRate     Decimal  @map("exchange_rate") @db.Decimal(40, 0)
  timestampMs      BigInt   @map("timestamp_ms")
  createdAt        DateTime @default(now()) @map("created_at")

  @@index([vaultId])
  @@index([depositor])
  @@index([timestampMs])
  @@map("sy_deposits")
}

/// SY redemptions (SY → underlying unwrap)
model SyRedemption {
  id               Int      @id @default(autoincrement())
  txDigest         String   @map("tx_digest")
  vaultId          String   @map("vault_id")
  vault            SyVault  @relation(fields: [vaultId], references: [id])
  redeemer         String
  syAmount         Decimal  @map("sy_amount") @db.Decimal(40, 0)
  underlyingAmount Decimal  @map("underlying_amount") @db.Decimal(40, 0)
  exchangeRate     Decimal  @map("exchange_rate") @db.Decimal(40, 0)
  timestampMs      BigInt   @map("timestamp_ms")
  createdAt        DateTime @default(now()) @map("created_at")

  @@index([vaultId])
  @@index([redeemer])
  @@index([timestampMs])
  @@map("sy_redemptions")
}

/// PT + YT minting events
model PyMint {
  id             Int      @id @default(autoincrement())
  txDigest       String   @map("tx_digest")
  marketId       String   @map("market_id")
  market         Market   @relation(fields: [marketId], references: [id])
  minter         String
  syConsumed     Decimal  @map("sy_consumed") @db.Decimal(40, 0)
  ptMinted       Decimal  @map("pt_minted") @db.Decimal(40, 0)
  ytMinted       Decimal  @map("yt_minted") @db.Decimal(40, 0)
  timestampMs    BigInt   @map("timestamp_ms")
  createdAt      DateTime @default(now()) @map("created_at")

  @@index([marketId])
  @@index([minter])
  @@index([timestampMs])
  @@map("py_mints")
}

/// AMM swap events
model Swap {
  id          Int      @id @default(autoincrement())
  txDigest    String   @map("tx_digest")
  marketId    String   @map("market_id")
  market      Market   @relation(fields: [marketId], references: [id])
  poolId      String   @map("pool_id")
  trader      String
  direction   String                                    // "sy_to_pt" | "pt_to_sy"
  amountIn    Decimal  @map("amount_in") @db.Decimal(40, 0)
  amountOut   Decimal  @map("amount_out") @db.Decimal(40, 0)
  fee         Decimal  @default(0) @db.Decimal(40, 0)
  impliedRate Decimal  @map("implied_rate") @db.Decimal(40, 18) // post-swap rate
  ptPrice     Float    @map("pt_price")                 // post-swap PT price
  timestampMs BigInt   @map("timestamp_ms")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([marketId])
  @@index([poolId])
  @@index([trader])
  @@index([timestampMs])
  @@map("swaps")
}

/// Add/remove liquidity events
model LiquidityEvent {
  id          Int      @id @default(autoincrement())
  txDigest    String   @map("tx_digest")
  marketId    String   @map("market_id")
  market      Market   @relation(fields: [marketId], references: [id])
  poolId      String   @map("pool_id")
  provider    String
  action      String                                    // "add" | "remove"
  syAmount    Decimal  @map("sy_amount") @db.Decimal(40, 0)
  ptAmount    Decimal  @map("pt_amount") @db.Decimal(40, 0)
  lpAmount    Decimal  @map("lp_amount") @db.Decimal(40, 0)
  timestampMs BigInt   @map("timestamp_ms")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([marketId])
  @@index([provider])
  @@index([timestampMs])
  @@map("liquidity_events")
}

/// Exchange rate changes (vault-level)
model RateSnapshot {
  id          Int      @id @default(autoincrement())
  vaultId     String   @map("vault_id")
  vault       SyVault  @relation(fields: [vaultId], references: [id])
  oldRate     Decimal  @map("old_rate") @db.Decimal(40, 0)
  newRate     Decimal  @map("new_rate") @db.Decimal(40, 0)
  timestampMs BigInt   @map("timestamp_ms")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([vaultId])
  @@index([timestampMs])
  @@map("rate_snapshots")
}

/// Market settlement events
model MarketSettlement {
  id               Int      @id @default(autoincrement())
  marketId         String   @map("market_id")
  market           Market   @relation(fields: [marketId], references: [id])
  settlementIndex  Decimal  @map("settlement_index") @db.Decimal(40, 0)
  maturityMs       BigInt   @map("maturity_ms")
  timestampMs      BigInt   @map("timestamp_ms")
  createdAt        DateTime @default(now()) @map("created_at")

  @@index([marketId])
  @@map("market_settlements")
}

// ─────────────────────────────────────────────────────────────
// TIME-SERIES ANALYTICS
// ─────────────────────────────────────────────────────────────

/// Implied rate snapshots (for yield curve history charts)
model ImpliedRateSnapshot {
  id          Int      @id @default(autoincrement())
  marketId    String   @map("market_id")
  market      Market   @relation(fields: [marketId], references: [id])
  impliedRate Float    @map("implied_rate")
  ptPrice     Float    @map("pt_price")
  ptReserve   Decimal  @map("pt_reserve") @db.Decimal(40, 0)
  syReserve   Decimal  @map("sy_reserve") @db.Decimal(40, 0)
  tvl         Float
  timestamp   DateTime @default(now())

  @@index([marketId, timestamp])
  @@map("implied_rate_snapshots")
}

/// Rolling 24h volume snapshots per market
model VolumeSnapshot {
  id        Int      @id @default(autoincrement())
  marketId  String   @map("market_id")
  market    Market   @relation(fields: [marketId], references: [id])
  volume    Float                                       // SY-denominated
  swapCount Int      @map("swap_count")
  fees      Float
  timestamp DateTime @default(now())

  @@index([marketId, timestamp])
  @@map("volume_snapshots")
}

/// Protocol-wide daily stats (for dashboard charts)
model DailyStats {
  id            Int      @id @default(autoincrement())
  date          DateTime @unique @db.Date
  totalTvl      Float    @map("total_tvl")
  totalVolume   Float    @map("total_volume")
  totalSwaps    Int      @map("total_swaps")
  totalMints    Int      @map("total_mints")
  totalRedeems  Int      @map("total_redeems")
  uniqueUsers   Int      @map("unique_users")
  totalFees     Float    @map("total_fees")
  createdAt     DateTime @default(now()) @map("created_at")

  @@map("daily_stats")
}

// ─────────────────────────────────────────────────────────────
// USER TRACKING
// ─────────────────────────────────────────────────────────────

/// Unique protocol users with aggregated stats
model User {
  id             String   @id                           // Sui address
  firstSeenAt    DateTime @default(now()) @map("first_seen_at")
  lastActiveAt   DateTime @default(now()) @map("last_active_at")
  totalDeposited Decimal  @default(0) @map("total_deposited") @db.Decimal(40, 0)
  totalSwapVol   Decimal  @default(0) @map("total_swap_vol") @db.Decimal(40, 0)
  swapCount      Int      @default(0) @map("swap_count")
  mintCount      Int      @default(0) @map("mint_count")

  @@index([lastActiveAt])
  @@map("users")
}

// ─────────────────────────────────────────────────────────────
// GOVERNANCE
// ─────────────────────────────────────────────────────────────

/// Governance proposals (cached from on-chain)
model Proposal {
  id           Int      @id                              // on-chain proposal ID
  proposer     String
  title        String
  description  String   @db.Text
  forVotes     Decimal  @default(0) @map("for_votes") @db.Decimal(40, 0)
  againstVotes Decimal  @default(0) @map("against_votes") @db.Decimal(40, 0)
  startTimeMs  BigInt   @map("start_time_ms")
  endTimeMs    BigInt   @map("end_time_ms")
  executed     Boolean  @default(false)
  status       String   @default("active")               // active | passed | failed | executed
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  votes        Vote[]

  @@index([status])
  @@map("proposals")
}

/// Individual votes on proposals
model Vote {
  id          Int      @id @default(autoincrement())
  proposalId  Int      @map("proposal_id")
  proposal    Proposal @relation(fields: [proposalId], references: [id])
  voter       String
  support     Boolean                                    // true = for, false = against
  weight      Decimal  @db.Decimal(40, 0)
  timestampMs BigInt   @map("timestamp_ms")
  createdAt   DateTime @default(now()) @map("created_at")

  @@unique([proposalId, voter])
  @@index([voter])
  @@map("votes")
}

// ─────────────────────────────────────────────────────────────
// TRANCHE ENGINE
// ─────────────────────────────────────────────────────────────

/// Tranche deposit/withdraw events
model TrancheEvent {
  id          Int      @id @default(autoincrement())
  txDigest    String   @map("tx_digest")
  vaultId     String   @map("vault_id")
  user        String
  tranche     String                                    // "senior" | "junior"
  action      String                                    // "deposit" | "withdraw"
  amount      Decimal  @db.Decimal(40, 0)
  timestampMs BigInt   @map("timestamp_ms")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([vaultId])
  @@index([user])
  @@index([timestampMs])
  @@map("tranche_events")
}

// ─────────────────────────────────────────────────────────────
// FEE TRACKING
// ─────────────────────────────────────────────────────────────

/// Fee collection events
model FeeCollection {
  id          Int      @id @default(autoincrement())
  txDigest    String   @map("tx_digest")
  source      String                                    // "swap" | "mint" | "flash_mint" | "tranche"
  poolId      String?  @map("pool_id")
  amount      Decimal  @db.Decimal(40, 0)
  coinType    String   @map("coin_type")
  timestampMs BigInt   @map("timestamp_ms")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([source])
  @@index([timestampMs])
  @@map("fee_collections")
}

// ─────────────────────────────────────────────────────────────
// INDEXER STATE
// ─────────────────────────────────────────────────────────────

/// Cursor tracking for event polling (per module)
model IndexerCursor {
  module      String   @id
  txDigest    String?  @map("tx_digest")
  eventSeq    Int?     @map("event_seq")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("indexer_cursors")
}
